{
  "redirects": [
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|favicon\\.png|og-image\\.jpg|icon\\.png|_next).+)",
      "destination": "https://geoeskort.com/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Cache-Control", "value": "s-maxage=86400, stale-while-revalidate" }
      ]
    }
  ]
}
